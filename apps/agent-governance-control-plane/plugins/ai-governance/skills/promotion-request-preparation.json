  "required_profile_fields": ["ai_governance_owner", "human_review_required"],
  "permitted_connectors": ["supabase-internal"],
  "required_evidence": ["promotion_request_draft"],
  "expected_outputs": ["promotion_request_draft"],
  "authority_requirements": { "requires_authority_context": true, "minimum_role": "admin" },
  "escalation_conditions": ["evidence_status incomplete", "authority_status not confirmed"],
  "audit_events": ["plugin.skill.run.started", "plugin.skill.run.rejected", "plugin.promotion_request.created"],
  "production_approval_status": false
