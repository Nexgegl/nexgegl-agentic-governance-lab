# Copy this file to .env.local and fill in the values from your Supabase
# project (Project Settings -> API). .env.local is already excluded from
# git via .gitignore (.env*.local) — never commit real values.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SUPABASE_SERVICE_ROLE_KEY is intentionally NOT listed here.
# It must never be read by client-side code or any code reachable from a
# browser request (see lib/supabase/client.ts, lib/supabase/server.ts).
# Only add it to the environment of server-only local tooling that
# specifically needs it (e.g. an admin seeding script run from a terminal),
# and never commit it or print its value.

# KFSA Runtime Core (server-only -- never NEXT_PUBLIC_-prefixed, never read
# by client-side code; see lib/kfsa/client.ts and
# docs/plugins/kfsa-integration-boundary.md). Only the Governance Gateway
# route at app/api/kfsa/promotion-requests calls this.
KFSA_RUNTIME_BASE_URL=https://your-kfsa-runtime-core.example.com
KFSA_RUNTIME_API_KEY=your-kfsa-server-to-server-api-key
# Optional; defaults to 15000ms if unset.
KFSA_RUNTIME_TIMEOUT_MS=15000
