# Copy this file to .env.local and fill in the values from your Supabase
# project (Project Settings -> API). .env.local is already excluded from
# git via .gitignore (.env*.local) — never commit real values.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SUPABASE_SERVICE_ROLE_KEY is intentionally NOT listed here.
# It must never be read by client-side code or any code reachable from a
# browser request (see lib/supabase/client.ts, lib/supabase/server.ts).
# Only add it to the environment of server-only code that specifically
# needs it -- an admin seeding script run from a terminal, or
# lib/supabase/admin.ts's service-role client (used only by
# POST /api/kfsa/promotion-requests for the KFSA-integration writes; see
# docs/plugins/kfsa-promotion-request-integration-v1.md) -- and never
# commit it or print its value.

# KFSA Runtime Core (server-only -- never NEXT_PUBLIC_-prefixed, never read
# by client-side code; see lib/kfsa/client.ts and
# docs/plugins/kfsa-integration-boundary.md). Only the Governance Gateway
# route at app/api/kfsa/promotion-requests calls this.
KFSA_RUNTIME_BASE_URL=https://your-kfsa-runtime-core.example.com
KFSA_RUNTIME_API_KEY=your-kfsa-server-to-server-api-key
# Optional; defaults to 15000ms if unset.
KFSA_RUNTIME_TIMEOUT_MS=15000
# Optional; defaults to 1000000 bytes (1 MB) if unset. Bounds how much of
# an external response body lib/kfsa/client.ts will read before rejecting
# it as invalid_response.
KFSA_RUNTIME_MAX_RESPONSE_BYTES=1000000
# Optional; defaults to 300000ms (5 minutes) if unset. How long an
# in_progress submission attempt is trusted to still be genuinely in
# flight before lib/kfsa/promotion-submission.ts may mark it stale and
# allow a new attempt.
KFSA_SUBMISSION_STALE_AFTER_MS=300000
